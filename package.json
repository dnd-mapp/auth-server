{
  "name": "@dnd-mapp/auth-server",
  "version": "0.0.0",
  "description": "",
  "author": "NoNamer777",
  "private": true,
  "license": "MIT",
  "scripts": {
    "gen:ssl-certs": "mkcert -cert-file ssl-cert.pem -key-file ssl-key.pem localhost.auth.dndmapp.dev localhost 127.0.0.1",
    "build": "pnpm exec nest build",
    "start": "pnpm exec nest start",
    "test:ci": "pnpm exec vitest run",
    "test:development": "pnpm exec vitest --ui --watch",
    "lint": "pnpm lint:eslint && pnpm lint:markdownlint",
    "lint:eslint": "pnpm exec eslint \"{src,test}/**/*\" --cache",
    "lint:markdownlint": "pnpm exec markdownlint \"**/*.md\"",
    "format:check": "pnpm exec prettier -l .",
    "format:write": "pnpm exec prettier -w ."
  },
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.31.0"
  },
  "dependencies": {
    "@nestjs/common": "~11.1",
    "@nestjs/core": "~11.1",
    "@nestjs/platform-express": "~11.1",
    "reflect-metadata": "~0.2",
    "rxjs": "~7.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.3",
    "@eslint/js": "~10.0",
    "@nestjs/cli": "~11.0",
    "@nestjs/schematics": "~11.0",
    "@nestjs/testing": "~11.1",
    "@types/node": "~24.12",
    "@types/supertest": "~7.2",
    "@vitest/coverage-v8": "~4.1",
    "@vitest/ui": "~4.1",
    "eslint": "~10.0",
    "eslint-config-prettier": "~10.1",
    "globals": "~17.4",
    "markdownlint": "~0.40",
    "markdownlint-cli": "~0.48.0",
    "prettier": "~3.8",
    "prettier-plugin-organize-imports": "~4.3",
    "source-map-support": "~0.5",
    "supertest": "~7.2",
    "ts-loader": "~9.5",
    "ts-node": "~10.9",
    "tsconfig-paths": "~4.2",
    "typescript": "~5.9",
    "typescript-eslint": "~8.57",
    "vite": "~8.0",
    "vitest": "~4.1"
  }
}
